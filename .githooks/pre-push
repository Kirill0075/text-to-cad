#!/bin/sh
set -eu

remote_name="${1:-}"
remote_url="${2:-}"
zero_sha="0000000000000000000000000000000000000000"
branches="${VERCEL_BLOB_UPLOAD_BRANCHES:-demo}"
should_upload=0

matches_branch() {
  candidate="$1"
  old_ifs="$IFS"
  IFS=", "
  for branch in $branches; do
    if [ "$candidate" = "$branch" ]; then
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi
  local_branch="${local_ref#refs/heads/}"
  remote_branch="${remote_ref#refs/heads/}"
  if matches_branch "$local_branch" || matches_branch "$remote_branch"; then
    should_upload=1
  fi
done

if [ "$should_upload" -ne 1 ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
viewer_dir="$repo_root/skills/render/scripts/viewer"
manifest_path="skills/render/scripts/viewer/.vercel-blob-assets.json"

if [ -z "${BLOB_READ_WRITE_TOKEN:-}" ] && [ ! -f "$viewer_dir/.env" ]; then
  cat >&2 <<EOF
pre-push: BLOB_READ_WRITE_TOKEN is required to upload demo CAD assets.
Set it in $viewer_dir/.env or export it in your shell.
EOF
  exit 1
fi

echo "pre-push: uploading demo CAD assets to Vercel Blob before pushing to $remote_name ($remote_url)"
npm --prefix "$viewer_dir" run upload:blob:demo

if ! git -C "$repo_root" ls-files --error-unmatch "$manifest_path" >/dev/null 2>&1; then
  cat >&2 <<EOF
pre-push: created $manifest_path.
Commit that manifest, then push again so Vercel can build without uploading assets.
EOF
  exit 1
fi

if ! git -C "$repo_root" diff --quiet -- "$manifest_path" ||
   ! git -C "$repo_root" diff --cached --quiet -- "$manifest_path"; then
  cat >&2 <<EOF
pre-push: $manifest_path changed after uploading assets.
Commit the refreshed manifest, then push again.
EOF
  exit 1
fi
